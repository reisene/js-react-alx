{
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 4,
    "printWidth": 250,
    "semi": true,
    "overrides": [
        {
            "files": [
                "*.json",
                "*.jsonc"
            ],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
